options:
  parameters:
    author: ''
    catch_exceptions: 'True'
    category: Custom
    cmake_opt: ''
    comment: ''
    copyright: ''
    description: USRP OFDM radar zero-Doppler range profile with 1D ESPRIT range estimation.
      RX packet_len tags via echotimer; range spectrum via range_profile_plot (PyQtGraph).
      Stop via GUI (not kill -9) so file_meta segments flush completely.
    gen_cmake: 'On'
    gen_linking: dynamic
    generate_options: qt_gui
    hier_block_src_path: .:..
    id: usrp_ofdm_echotimer_dd_esprit
    max_nouts: '0'
    output_language: python
    placement: (0,0)
    qt_qss_theme: ''
    realtime_scheduling: ''
    run: 'True'
    run_command: '{python} -u {filename}'
    run_options: prompt
    sizing_mode: fixed
    thread_safe_setters: ''
    title: ''
    window_size: 2000,2000
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [10, 10]
    rotation: 0
    state: enabled

blocks:
- name: RX_gain
  id: variable_qtgui_range
  parameters:
    comment: ''
    gui_hint: ''
    label: RX Gain
    min_len: '200'
    orient: QtCore.Qt.Horizontal
    rangeType: float
    start: '0'
    step: '1'
    stop: '50'
    value: '30'
    widget: counter_slider
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [2600, 492.0]
    rotation: 0
    state: enabled
- name: R_max
  id: variable
  parameters:
    comment: "\u6700\u5927\u4E0D\u6A21\u7CCA\u8DDD\u79BB (m)\uFF0CR = c/(2\xB7BW)\xB7\
      N_fft"
    value: 3e8/2/samp_rate*fft_len
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [1200, 16.0]
    rotation: 0
    state: enabled
- name: TX_gain
  id: variable_qtgui_range
  parameters:
    comment: ''
    gui_hint: ''
    label: TX Gain
    min_len: '200'
    orient: QtCore.Qt.Horizontal
    rangeType: float
    start: '0'
    step: '1'
    stop: '50'
    value: '30'
    widget: counter_slider
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [2480, 492.0]
    rotation: 0
    state: enabled
- name: esprit_enable
  id: variable_qtgui_check_box
  parameters:
    comment: Enable 1D range ESPRIT on CPI complex range profile
    'false': 'False'
    gui_hint: 2,4,1,1
    label: ESPRIT Enable
    'true': 'True'
    type: bool
    value: 'True'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [1320, 200.0]
    rotation: 0
    state: enabled
- name: esprit_num_sources
  id: variable_qtgui_range
  parameters:
    comment: Number of range targets for 1D ESPRIT
    gui_hint: ''
    label: ESPRIT Num Sources
    min_len: '200'
    orient: QtCore.Qt.Horizontal
    rangeType: float
    start: '1'
    step: '1'
    stop: '5'
    value: '1'
    widget: counter_slider
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [1480, 200.0]
    rotation: 0
    state: enabled
- name: factor
  id: variable_qtgui_range
  parameters:
    comment: ''
    gui_hint: ''
    label: ''
    min_len: '200'
    orient: QtCore.Qt.Horizontal
    rangeType: float
    start: '0'
    step: '0.001'
    stop: '1'
    value: '0.004'
    widget: counter_slider
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [2280, 220.0]
    rotation: 0
    state: enabled
- name: fft_len
  id: variable
  parameters:
    comment: ''
    value: '2048'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [176, 8.0]
    rotation: 0
    state: enabled
- name: frame_rate_hz
  id: variable
  parameters:
    comment: CPI range-profile frame rate written into file_meta header
    value: samp_rate / (transpose_len * (fft_len + fft_len // 4))
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [880, 16.0]
    rotation: 0
    state: enabled
- name: freq
  id: variable
  parameters:
    comment: "\u8F7D\u9891 (Hz)\uFF1B\u987B\u4E0E v_max \u516C\u5F0F\u4E00\u81F4\uFF0C\
      \u5426\u5219\u901F\u5EA6\u4F30\u8BA1\u4F1A\u504F"
    value: 6.0e9
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [1472, 16.0]
    rotation: 0
    state: enabled
- name: length_tag_key
  id: variable
  parameters:
    comment: ''
    value: '"packet_len"'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [408, 8.0]
    rotation: 0
    state: enabled
- name: min_out_buf_val
  id: variable
  parameters:
    comment: ''
    value: packet_len*2
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [1304, 16.0]
    rotation: 0
    state: enabled
- name: n_carriers
  id: variable
  parameters:
    comment: occupied subcarriers (full band minus DC); matches gr_setup.resolve_gr_carrier_tuples
    value: fft_len - 2
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [200, 128.0]
    rotation: 0
    state: enabled
- name: num_delay_samp
  id: variable_qtgui_range
  parameters:
    comment: Recalibrate after fft_len/rate change; align loopback peak to 0 m
    gui_hint: ''
    label: Number of delayed samples
    min_len: '200'
    orient: QtCore.Qt.Horizontal
    rangeType: float
    start: '0'
    step: '1'
    stop: packet_len
    value: '281'
    widget: counter_slider
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [2288, 492.0]
    rotation: 0
    state: enabled
- name: occupied_carriers
  id: variable
  parameters:
    comment: ''
    value: list((list(range(-n_carriers//2, 0)) + list(range(1, n_carriers//2 + 1)),))
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [520, 120.0]
    rotation: 0
    state: enabled
- name: packet_len
  id: variable
  parameters:
    comment: QPSK bytes per burst; derived from CPI symbol count
    value: transpose_len * n_carriers // 4
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [560, 16.0]
    rotation: 0
    state: enabled
- name: payload_mod
  id: variable
  parameters:
    comment: ''
    value: digital.constellation_qpsk()
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [16, 128.0]
    rotation: 0
    state: enabled
- name: qpsk_symbols_per_packet
  id: variable
  parameters:
    comment: QPSK complex symbols per burst after repack_bits
    value: transpose_len * n_carriers
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [872, 128.0]
    rotation: 0
    state: enabled
- name: range_bin_step
  id: variable
  parameters:
    comment: "\u8DDD\u79BB\u8C31\u6A21\u8F74\u6B65\u8FDB (m/bin)"
    value: R_max/(fft_len*zeropadding_fac)
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [1064, 16.0]
    rotation: 0
    state: enabled
- name: range_roi
  id: variable
  parameters:
    comment: ROI display range (min_m, max_m) for range profile GUI
    value: (0.0, 30.0)
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [1680, 136.0]
    rotation: 0
    state: enabled
- name: record_enable
  id: variable_qtgui_check_box
  parameters:
    comment: Set True to record linear-power range profiles to disk
    'false': 'False'
    gui_hint: 1,4,1,1
    label: Record Enable
    'true': 'True'
    type: bool
    value: 'False'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [1176, 92.0]
    rotation: 0
    state: enabled
- name: record_file_path
  id: variable
  parameters:
    comment: Fixed absolute path shared with range_profile_playback.grc
    value: '"/home/caict/Desktop/isac/gnuradio/tests/data_collection/usrp_ofdm_echotimer_dd_data_collection_esprit/dataset/run_001/range_profiles"'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [1960, 96.0]
    rotation: 0
    state: enabled
- name: record_output_index
  id: variable
  parameters:
    comment: Selector output; 0=file_sink, 1=null_sink
    value: 0 if record_enable else 1
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [1480, 136.0]
    rotation: 0
    state: enabled
- name: samp_rate
  id: variable
  parameters:
    comment: ''
    value: int(fft_len * subcarrier_spacing)
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [280, 8.0]
    rotation: 0
    state: enabled
- name: subcarrier_spacing
  id: variable
  parameters:
    comment: ''
    value: 120e3
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [344, 120.0]
    rotation: 0
    state: enabled
- name: transpose_len
  id: variable
  parameters:
    comment: CPI OFDM symbols per burst; 4 avoids qpsk>8192 sched limit at fft_len=2048
    value: '4'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [736, 8.0]
    rotation: 0
    state: enabled
- name: uhd_dev_args
  id: variable
  parameters:
    comment: 'X410 349B642; QSFP 10.2; external 10MHz+PPS: clock/time=external in
      args and Echotimer'
    value: '"type=x4xx,serial=349B642,mgmt_addr=192.168.1.100,addr=192.168.10.2,clock_source=external,time_source=external"'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [2304, 704.0]
    rotation: 0
    state: enabled
- name: wait_to_start
  id: variable
  parameters:
    comment: ''
    value: '0.03'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [2144, 488.0]
    rotation: 0
