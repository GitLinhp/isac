  parameters:
    _source_code: "import sys\nfrom pathlib import Path\nfor _p in [Path.cwd(), *Path.cwd().parents]:\n\
      \    _src = _p / \"src\"\n    if (_src / \"isac_imp\").is_dir():\n        sys.path.insert(0,\
      \ str(_src))\n        break\nfrom isac_imp.range_esprit_block import RangeEspritBlock\n\
      \nblk = RangeEspritBlock\n"
    affinity: ''
    alias: ''
    comment: 1D range ESPRIT on CPI complex range profile; parallel to recording chain
    esprit_enable: esprit_enable
    maxoutbuf: '0'
