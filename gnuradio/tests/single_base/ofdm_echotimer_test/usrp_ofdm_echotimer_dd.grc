    alias: ''
    comment: ''
    fft_size: transpose_len
    forward: 'False'
    maxoutbuf: '0'
    minoutbuf: '0'
    nthreads: '1'
    shift: 'False'
    type: complex
    window: window.blackmanharris(transpose_len)
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [104, 692.0]
    rotation: 0
    state: enabled
- name: ofdm_cpi_tag_normalizer_rx_0
  id: epy_block
  parameters:
    _source_code: 'from isac_imp.ofdm_cpi_tag_normalizer import OfdmCpiTagNormalizerBlock


      blk = OfdmCpiTagNormalizerBlock

      '
    affinity: ''
    alias: ''
    comment: Retag RX FFT for GR divide (packet_len=transpose_len symbols)
    fft_len: fft_len
    length_tag_key: length_tag_key
    maxoutbuf: '0'
    minoutbuf: 2*transpose_len
    transpose_len: transpose_len
  states:
    _io_cache: "('OFDM CPI Tag Normalizer', 'OfdmCpiTagNormalizerBlock', [('fft_len',\
      \ '2048'), ('transpose_len', '4'), ('length_tag_key', \"'packet_len'\")], [('0',\
      \ 'complex', 2048)], [('0', 'complex', 2048)], '1:1 \u900F\u4F20\u9891\u57DF\
      \u5411\u91CF\uFF1B\u6BCF CPI \u9996\u7B26\u53F7\u6253 ``packet_len=transpose_len``\
      \ tag\u3002', [])"
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [1208, 516.0]
    rotation: 180
    state: enabled
- name: ofdm_cpi_tag_normalizer_tx_0
  id: epy_block
  parameters:
    _source_code: 'from isac_imp.ofdm_cpi_tag_normalizer import OfdmCpiTagNormalizerBlock


      blk = OfdmCpiTagNormalizerBlock

      '
    affinity: ''
    alias: ''
    comment: Retag GR TX ref for GR divide (packet_len=transpose_len symbols)
    fft_len: fft_len
    length_tag_key: length_tag_key
    maxoutbuf: '0'
    minoutbuf: 2*transpose_len
    transpose_len: transpose_len
  states:
    _io_cache: "('OFDM CPI Tag Normalizer', 'OfdmCpiTagNormalizerBlock', [('fft_len',\
      \ '2048'), ('transpose_len', '4'), ('length_tag_key', \"'packet_len'\")], [('0',\
      \ 'complex', 2048)], [('0', 'complex', 2048)], '1:1 \u900F\u4F20\u9891\u57DF\
      \u5411\u91CF\uFF1B\u6BCF CPI \u9996\u7B26\u53F7\u6253 ``packet_len=transpose_len``\
      \ tag\u3002', [])"
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [1328, 452.0]
    rotation: 180
    state: enabled
